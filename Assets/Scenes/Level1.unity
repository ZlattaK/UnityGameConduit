  m_GameObject: {fileID: 1359576286}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 226631e2855c40b48ab281c8357c774f, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  boxOpen: {fileID: 541842795}
  puzzle: {fileID: 1672444123}
  formPuzzle: {fileID: 996034905}
  dialogController: {fileID: 1552396341}
  dialogLines:
  - "\u0422\u0430 \u0441\u0430\u043C\u0430\u044F \u043A\u0430\u0440\u0442\u0430 \u0438\u0437
    \u0434\u043D\u0435\u0432\u043D\u0438\u043A\u0430\u2026 \u0414\u043E \u0421\u0442\u0430\u0440\u043E\u0433\u043E
    \u0441\u0435\u043A\u0442\u043E\u0440\u0430 \u043D\u0435 \u0434\u043E\u0431\u0440\u0430\u0442\u044C\u0441\u044F
    \u2014 \u043C\u043E\u0441\u0442 \u043C\u043E\u0436\u0435\u0442 \u043D\u0435 \u0432\u044B\u0434\u0435\u0440\u0436\u0430\u0442\u044C.
    \u0410 \u0432\u043E\u0442 \u0432 \u0430\u043D\u043E\u043C\u0430\u043B\u044C\u043D\u0443\u044E
    \u0437\u043E\u043D\u0443 \u043F\u0443\u0442\u044C \u0432\u044B\u0433\u043B\u044F\u0434\u0438\u0442
    \u043F\u0440\u043E\u0449\u0435. "
  - "\u041F\u043E\u0445\u043E\u0436\u0435, \u0432\u0441\u0451 \u043D\u0430\u0447\u0430\u043B\u043E\u0441\u044C
    \u0438\u043C\u0435\u043D\u043D\u043E \u043E\u0442\u0441\u044E\u0434\u0430\u2026
    \u0415\u0441\u043B\u0438 \u043A\u0430\u043C\u0435\u043D\u044C \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u0438\u0437 \u0437\u043E\u043D\u044B, \u0437\u043D\u0430\u0447\u0438\u0442,
    \u043E\u0442\u0432\u0435\u0442\u044B \u0442\u043E\u0436\u0435 \u043D\u0443\u0436\u043D\u043E
    \u0438\u0441\u043A\u0430\u0442\u044C \u0442\u0430\u043C."
  dialogDelay: 0.3
