  m_Name: 
  m_EditorClassIdentifier: 
  plantController: {fileID: 1405015291}
  dialogController: {fileID: 1552396341}
  blockedLines:
  - "\u0420\u0430\u0441\u0442\u0435\u043D\u0438\u044F-\u043C\u0443\u0442\u0430\u043D\u0442\u044B
    \u043C\u0435\u0448\u0430\u044E\u0442 \u043F\u0440\u043E\u0431\u0440\u0430\u0442\u044C\u0441\u044F
    \u043A \u044D\u0442\u043E \u0448\u0442\u0443\u043A\u0435!"
  openLines:
  - "\u042D\u0442\u043E \u0435\u0449\u0451 \u0447\u0442\u043E\u2026 \u041E\u043D
    \u043D\u0435 \u043F\u043E\u0445\u043E\u0436 \u043D\u0430 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430\u2026
    \u0440\u0435\u043F\u0442\u0438\u043B\u043E\u0438\u0434?.. \u043D\u0435\u0442,
    \u043D\u0435\u0432\u0430\u0436\u043D\u043E. \u0413\u043B\u0430\u0432\u043D\u043E\u0435
    \u2014 \u044D\u0442\u043E\u0442 \u043A\u0443\u043B\u043E\u043D."
  - "\u0415\u0441\u043B\u0438 \u043E\u043D \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0442\u0435\u043B\u044C\u043D\u043E
    \u0441\u0432\u044F\u0437\u0430\u043D \u0441 \u044D\u0442\u0438\u043C \u043C\u0435\u0441\u0442\u043E\u043C,
    \u043C\u043D\u0435 \u043E\u043D \u043D\u0443\u0436\u0435\u043D. \u0422\u043E\u043B\u044C\u043A\u043E
    \u0431\u044B \u044F \u0443\u0441\u043F\u0435\u043B \u0440\u0430\u0437\u043E\u0431\u0440\u0430\u0442\u044C\u0441\u044F
    \u0434\u043E \u0442\u043E\u0433\u043E, \u043A\u0430\u043A \u0432\u0441\u0451
    \u044D\u0442\u043E \u043E\u043A\u043E\u043D\u0447\u0430\u0442\u0435\u043B\u044C\u043D\u043E
    \u0432\u044B\u0439\u0434\u0435\u0442 \u0438\u0437-\u043F\u043E\u0434 \u043A\u043E\u043D\u0442\u0440\u043E\u043B\u044F\u2026"
  ufoOpen: {fileID: 1007519062}
