--- !u!114 &1714495356
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1714495354}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 27f3b3ef3a7e9cb49b88b394cccacaa7, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  fileName: read_me.txt
  fileText: "\u042D\u043A\u0441\u043F\u0435\u0434\u0438\u0446\u0438\u044F A-6.\r\n\u0417\u0430\u043F\u0438\u0441\u044C
    \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u0435\u0442\u0441\u044F\u2026
    \u0435\u0441\u043B\u0438 \u044D\u0442\u043E \u0432\u0441\u0451 \u0435\u0449\u0451
    \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044F \u0437\u0430\u043F\u0438\u0441\u044C\u044E.\r\n\r\n\u041D\u0443\u043B\u0435\u0432\u043E\u0439
    \u0443\u0440\u043E\u0432\u0435\u043D\u044C \u043D\u0435\u0441\u0442\u0430\u0431\u0438\u043B\u0435\u043D.
    \u041C\u044B \u043E\u0448\u0438\u0431\u0430\u043B\u0438\u0441\u044C.\r\n\u041E\u043D
    \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043C\u0435\u043D\u044F\u0435\u0442\u0441\u044F
    \u2014 \u043E\u043D \u0440\u0435\u0430\u0433\u0438\u0440\u0443\u0435\u0442.\r\n\r\n4
    \u0440\u0430\u0437\u0430 \u0437\u0430 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435
    \u0441\u0443\u0442\u043A\u0438 \u043F\u0440\u0438\u0431\u043E\u0440\u044B \u0444\u0438\u043A\u0441\u0438\u0440\u043E\u0432\u0430\u043B\u0438
    \u043E\u0442\u043A\u043B\u0438\u043A \u0431\u0435\u0437 \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A\u0430.\r\n\u041C\u044B
    \u043F\u0440\u043E\u0432\u0435\u0440\u0438\u043B\u0438 \u0432\u0441\u0451. \u041E\u0448\u0438\u0431\u043A\u0430
    \u0438\u0441\u043A\u043B\u044E\u0447\u0435\u043D\u0430.\r\n\r\n7 \u0447\u0430\u0441\u043E\u0432
    \u043D\u0430\u0437\u0430\u0434 \u043E\u0434\u0438\u043D \u0438\u0437 \u0443\u0447\u0430\u0441\u0442\u043D\u0438\u043A\u043E\u0432
    \u0443\u0442\u0432\u0435\u0440\u0436\u0434\u0430\u043B, \u0447\u0442\u043E \u0441\u043B\u044B\u0448\u0430\u043B
    \u0441\u0438\u0433\u043D\u0430\u043B.\r\n\u041C\u044B \u043D\u0435 \u0437\u0430\u0444\u0438\u043A\u0441\u0438\u0440\u043E\u0432\u0430\u043B\u0438
    \u043D\u0438\u0447\u0435\u0433\u043E.\r\n\u041D\u043E \u043E\u043D \u043D\u0430\u0437\u0432\u0430\u043B
    \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442\u044B\u2026 \u0434\u043E
    \u0442\u043E\u0433\u043E, \u043A\u0430\u043A \u043C\u044B \u0438\u0445 \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0438.\r\n\r\n2
    \u043E\u0431\u044A\u0435\u043A\u0442\u0430 \u0431\u044B\u043B\u0438 \u043F\u0435\u0440\u0435\u043C\u0435\u0449\u0435\u043D\u044B
    \u0431\u0435\u0437 \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
    \u043A\u043E\u043D\u0442\u0430\u043A\u0442\u0430.\r\n\u0421\u043B\u0435\u0434\u043E\u0432
    \u0432\u043E\u0437\u0434\u0435\u0439\u0441\u0442\u0432\u0438\u044F \u043D\u0435\u0442.\r\n\r\n9
    \u043C\u0438\u043D\u0443\u0442 \u043D\u0430\u0437\u0430\u0434\u2026\r\n\u0437\u0430\u043F\u0438\u0441\u044C
    \u043F\u0440\u0435\u0440\u044B\u0432\u0430\u043B\u0430\u0441\u044C.\r\n\u042F
    \u043D\u0435 \u043F\u043E\u043C\u043D\u044E, \u0447\u0442\u043E \u043F\u0440\u043E\u0438\u0441\u0445\u043E\u0434\u0438\u043B\u043E
    \u0432 \u044D\u0442\u043E\u0442 \u043F\u0440\u043E\u043C\u0435\u0436\u0443\u0442\u043E\u043A.\r\n\r\n\u2026\r\n\r\n\u0415\u0441\u043B\u0438
    \u043A\u0442\u043E-\u0442\u043E \u043D\u0430\u0439\u0434\u0451\u0442 \u044D\u0442\u043E\u0442
    \u0444\u0430\u0439\u043B \u2014\r\n\u0434\u043E\u0441\u0442\u0443\u043F \u043A
    \u044F\u0449\u0438\u043A\u0443 \u0431\u044B\u043B \u043E\u0433\u0440\u0430\u043D\u0438\u0447\u0435\u043D
    \u043D\u0435 \u043D\u0430\u043C\u0438.\r\n\r\n\u041A\u043B\u044E\u0447 \u0431\u044B\u043B
    \u0441\u043A\u0440\u044B\u0442 \u0434\u043B\u044F \u0441\u043E\u0445\u0440\u0430\u043D\u043D\u043E\u0441\u0442\u0438.\r\n\u041D\u043E
    \u043D\u0430\u0431\u043B\u044E\u0434\u0430\u0442\u0435\u043B\u044C \u0432\u0441\u0435\u0433\u0434\u0430
    \u0432\u0438\u0434\u0438\u0442 \u0431\u043E\u043B\u044C\u0448\u0435, \u0447\u0435\u043C
    \u0443\u0447\u0430\u0441\u0442\u043D\u0438\u043A.\r\n\r\n\u0415\u0441\u043B\u0438
    \u0442\u044B \u0441\u043C\u043E\u0442\u0440\u0438\u0448\u044C \u2014\r\n\u0437\u043D\u0430\u0447\u0438\u0442,
