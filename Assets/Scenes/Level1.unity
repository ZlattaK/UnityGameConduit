  m_Script: {fileID: 11500000, guid: bd2da908059fe2c4ca98addc11c608ef, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogController: {fileID: 1552396341}
  lines:
  - "\u041D\u0435\u0431\u043E\u043B\u044C\u0448\u043E\u0439 \u043C\u0438\u043D\u0435\u0440\u0430\u043B
    \u0441\u0442\u0440\u0430\u043D\u043D\u043E\u0439 \u0444\u043E\u0440\u043C\u044B.
    \u041E\u0442\u0435\u0446 \u0445\u0440\u0430\u043D\u0438\u043B \u0435\u0433\u043E
    \u0441\u0440\u0435\u0434\u0438 \u043B\u0438\u0447\u043D\u044B\u0445 \u0432\u0435\u0449\u0435\u0439
    \u0438 \u043D\u0438\u043A\u043E\u0433\u0434\u0430 \u043D\u0435 \u043E\u0431\u044A\u044F\u0441\u043D\u044F\u043B,
    \u043E\u0442\u043A\u0443\u0434\u0430 \u043E\u043D \u043F\u043E\u044F\u0432\u0438\u043B\u0441\u044F."
  - "\u041A\u0430\u043C\u0435\u043D\u044C \u0431\u0443\u0434\u0442\u043E \u0435\u0434\u0432\u0430
    \u0432\u0438\u0431\u0440\u0438\u0440\u0443\u0435\u0442 \u0432 \u0440\u0443\u043A\u0435,
    \u043E\u0441\u0442\u0430\u0432\u043B\u044F\u044F \u043E\u0449\u0443\u0449\u0435\u043D\u0438\u0435
    \u0441\u043B\u0430\u0431\u043E\u0433\u043E \u044D\u0445\u043E-\u0448\u0443\u043C\u0430.\n\u041F\u0440\u043E\u0438\u0441\u0445\u043E\u0436\u0434\u0435\u043D\u0438\u0435
    \u043E\u0431\u044A\u0435\u043A\u0442\u0430 \u043E\u0441\u0442\u0430\u0451\u0442\u0441\u044F
    \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u043C."
