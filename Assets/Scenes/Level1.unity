  m_text: "\u041D\u0430\u0436\u043C\u0438 \u041F\u041A\u041C, \u0447\u0442\u043E\u0431\u044B
    \u0438\u0437\u0443\u0447\u0438\u0442\u044C \u043F\u0440\u0435\u0434\u043C\u0435\u0442.\r\n\n\u0417\u0430\u0436\u043C\u0438
    \u041B\u041A\u041C, \u0447\u0442\u043E\u0431\u044B \u043F\u0435\u0440\u0435\u0442\u0430\u0449\u0438\u0442\u044C
    \u043F\u0440\u0435\u0434\u043C\u0435\u0442 \u0432 \u0441\u043B\u043E\u0442 \u0438\u0432\u0435\u043D\u0442\u0430\u0440\u044F.\r\n\n\u041D\u0430\u0436\u043C\u0438
    \u041B\u041A\u041C \u043F\u043E \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u0443
    \u0432 \u0438\u043D\u0432\u0435\u043D\u0442\u0430\u0440\u0435, \u0447\u0442\u043E\u0431\u044B
    \u0443\u0431\u0440\u0430\u0442\u044C \u0435\u0433\u043E.\r\n\n\u041D\u0435 \u0432\u0441\u0451
    \u0441\u0442\u043E\u0438\u0442 \u0431\u0440\u0430\u0442\u044C, \u0432\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u043E
    \u0438\u0437\u0443\u0447\u0430\u0439, \u0447\u0442\u043E \u043C\u043E\u0436\u0435\u0442
    \u043F\u0440\u0438\u0433\u043E\u0434\u0438\u0442\u044C\u0441\u044F.\r\n\u0412\u043E
    \u0432\u0440\u0435\u043C\u044F \u0438\u0433\u0440\u044B \u043C\u043E\u0433\u0443\u0442
