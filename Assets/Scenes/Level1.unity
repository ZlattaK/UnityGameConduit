--- !u!114 &758676273
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 758676270}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 1a9fcdc8b1bae064ba92c1ae0c0dbab4, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogController: {fileID: 1552396341}
  lines:
  - "\u041D\u0443 \u043A\u043E\u043D\u0435\u0447\u043D\u043E. \u041E\u043F\u044F\u0442\u044C
    \u043D\u0435 \u043F\u0443\u0441\u0442\u0438\u043B\u0438. \u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E,
    \u0432\u043E\u043E\u0431\u0449\u0435 \u0445\u043E\u0442\u044C \u043A\u0442\u043E-\u0442\u043E
    \u0431\u044B\u0432\u0430\u043B \u0432 \u044D\u0442\u043E\u0439 \u0437\u043E\u043D\u0435
    \u043F\u043E\u0441\u043B\u0435 \u0442\u0435\u0445 \u0434\u0432\u0443\u0445 \u043F\u0440\u043E\u043F\u0430\u0432\u0448\u0438\u0445
    \u0433\u0440\u0443\u043F\u043F?"
  - "\u041B\u0430\u0434\u043D\u043E... \u0417\u0430\u0431\u0435\u0440\u0443 \u043F\u0440\u043E\u0442\u043E\u043A\u043E\u043B
    PX-3 \u0438 \u0437\u0430\u0433\u043B\u044F\u043D\u0443 \u0432 \u0431\u0430\u0440
    \u2014 \u043F\u044F\u0442\u043D\u0438\u0446\u0430 \u0436\u0435. \u041C\u043E\u0436\u0435\u0442,
    \u0442\u0430\u043C \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u0441\u044F \u0441\u043F\u043E\u043A\u043E\u0439\u043D\u043E
    \u0432\u0441\u0451 \u043F\u0435\u0440\u0435\u0441\u043C\u043E\u0442\u0440\u0435\u0442\u044C."
  passwordController: {fileID: 758676272}
