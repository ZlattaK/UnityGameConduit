--- !u!114 &193333606
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 193333599}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: bd2da908059fe2c4ca98addc11c608ef, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogController: {fileID: 1552396341}
  lines:
  - "\u0412 \u044D\u0442\u043E\u043C \u043E\u043A\u043D\u0435 \u043C\u043E\u0436\u043D\u043E
    \u043F\u0440\u043E\u0441\u043C\u0430\u0442\u0440\u0438\u0432\u0430\u0442\u044C
    \u0434\u0438\u0430\u043B\u043E\u0433\u0438, \u0443\u0437\u043D\u0430\u0432\u0430\u044F
    \u0431\u043E\u043B\u044C\u0448\u0435 \u043E \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u0435
    \u0438\u043B\u0438 \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u0436\u0435.\n\u041D\u0430\u0436\u043C\u0438
    \u043D\u0430 \u0437\u0435\u043B\u0435\u043D\u0443\u044E \u0441\u0442\u0440\u0435\u043B\u043A\u0443,
    \u0447\u0442\u043E\u0431\u044B \u043F\u043E\u0441\u043C\u043E\u0442\u0440\u0435\u0442\u044C
    \u0434\u0438\u0430\u043B\u043E\u0433 \u0434\u0430\u043B\u044C\u0448\u0435."
  - "\u0414\u043B\u044F \u0437\u0430\u043A\u0440\u044B\u0442\u0438\u044F \u043E\u043A\u043D\u0430
    \u0434\u0438\u0430\u043B\u043E\u0433\u0430 \u043D\u0430\u0436\u0438\u043C\u0430\u0439
    \u043D\u0430 \u043A\u0440\u0430\u0441\u043D\u044B\u0439 \u043A\u0440\u0435\u0441\u0442\u0438\u043A."
