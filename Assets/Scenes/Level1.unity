  backSprite: {fileID: 1567284936}
  frontSprite: {fileID: 625311689}
  fadeDuration: 0.2
  dialogController: {fileID: 1552396341}
  dialogLines:
  - "\u042F \u0432\u0435\u0434\u044C \u0433\u043E\u0432\u043E\u0440\u0438\u043B \u0442\u0435\u0431\u0435,
    \u0447\u0442\u043E \u0437\u043E\u043D\u0430 \u043D\u0435 \u0434\u043B\u044F \u043B\u044E\u0434\u0435\u0439.\r\n\u0410
    \u0442\u0435\u043F\u0435\u0440\u044C \u0441\u043C\u043E\u0442\u0440\u0438, \u043A\u0442\u043E
    \u0442\u044B \u0434\u043B\u044F \u043D\u0435\u0451. \u041F\u0440\u043E\u0447\u0442\u0438
    \u0437\u0430\u043F\u0438\u0441\u0438 \u043D\u0430 \u043F\u043B\u0430\u043D\u0448\u0435\u0442\u0435,
    \u0443\u0432\u0435\u0440\u0435\u043D \u043E\u043D\u0438 \u0442\u0435\u0431\u0435
    \u043F\u043E\u043D\u0440\u0430\u0432\u044F\u0442\u0441\u044F.\r\n"
