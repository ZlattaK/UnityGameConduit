--- !u!114 &1402563885
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1402563880}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: bd2da908059fe2c4ca98addc11c608ef, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialogController: {fileID: 1552396341}
  lines:
  - "\u0421\u0438\u0433\u043D\u0430\u043B\u2026 \u042D\u0442\u043E \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E
    \u043F\u043E\u043C\u0435\u0445\u0438\u2026 \u043E\u043D \u0440\u0435\u0430\u0433\u0438\u0440\u0443\u0435\u0442
    \u043D\u0430 \u0447\u0442\u043E-\u0442\u043E. \u0412 \u043B\u0430\u0431\u043E\u0440\u0430\u0442\u043E\u0440\u0438\u0438
    \u0431\u044B\u043B \u043F\u043E\u0445\u043E\u0436\u0438\u0439, \u043D\u043E \u044D\u0442\u043E\u0442\u2026
    \u043D\u0435 \u0438\u0449\u0435\u0442 \u043A\u043E\u043E\u0440\u0434\u0438\u043D\u0430\u0442\u044B\u2026
    \u041E\u043D \u0438\u0449\u0435\u0442 \u043E\u0442\u043A\u043B\u0438\u043A? "
  - "\u0415\u0441\u043B\u0438 \u0432\u0435\u0440\u0438\u0442\u044C \u043F\u043E\u043A\u0430\u0437\u0430\u043D\u0438\u044F\u043C\u2026
    \u0441\u0438\u0433\u043D\u0430\u043B \u0443\u0445\u043E\u0434\u0438\u0442 \u0432\u0433\u043B\u0443\u0431\u044C
    \u043B\u0435\u0441\u0430, \u044D\u0442\u043E \u0441\u043E\u0432\u043F\u0430\u0434\u0430\u0435\u0442
    \u0441 \u043A\u0430\u0440\u0442\u043E\u0439. \u041D\u0443\u0436\u043D\u043E \u0432\u0437\u044F\u0442\u044C
    \u0435\u0433\u043E \u0441 \u0441\u043E\u0431\u043E\u0439."
